---
const {
  title = 'Game Over',
  player1 = 'Player 1',
  player2 = 'Player 2',
  score1 = 0,
  score2 = 0,
  winner = '',
  actionText = 'Play Again',
  actionHref = '/',
} = Astro.props;

const winnerName = winner || (score1 > score2 ? player1 : score2 > score1 ? player2 : 'Draw');
const resultText = score1 === score2 ? 'It’s a draw!' : `${winnerName} wins!`;
---

<div class="game-over-screen">
  <div class="game-over-panel">
    <span class="game-over-badge">GAME OVER</span>
    <h2>{title}</h2>
    <p class="game-over-description">Battle complete. Review the final score and return to the arena.</p>

    <div class="score-card">
      <div class="score-item">
        <span class="score-label">{player1}</span>
        <span class="score-value">{score1}</span>
      </div>
      <div class="score-divider">–</div>
      <div class="score-item">
        <span class="score-label">{player2}</span>
        <span class="score-value">{score2}</span>
      </div>
    </div>

    <p class="winner-text">{resultText}</p>

    <div class="game-over-actions">
      <a class="game-over-button" href={actionHref}>{actionText}</a>
      <slot />
    </div>
  </div>
</div>

<style>
  .game-over-screen {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 10, 26, 0.85);
    z-index: 1000;
    padding: 20px;
  }

  .game-over-panel {
    width: min(520px, 100%);
    background: rgba(18, 18, 38, 0.98);
    border: 1px solid rgba(95, 237, 131, 0.4);
    border-radius: 24px;
    box-shadow: 0 0 60px rgba(95, 237, 131, 0.15);
    padding: 36px 32px;
    text-align: center;
    color: #ffffff;
  }

  .game-over-badge {
    display: inline-flex;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(95, 237, 131, 0.12);
    color: #5fed83;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .game-over-panel h2 {
    margin: 0;
    font-size: 2rem;
    color: #ffffff;
    letter-spacing: -0.03em;
  }

  .game-over-description {
    color: #bfc7d0;
    margin: 16px auto 24px;
    max-width: 420px;
    line-height: 1.7;
  }

  .score-card {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
    align-items: center;
    margin: 0 auto 24px;
    padding: 22px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
  }

  .score-item {
    display: grid;
    gap: 8px;
  }

  .score-label {
    color: #a3b1d1;
    font-size: 0.9rem;
  }

  .score-value {
    font-size: 2.25rem;
    font-weight: 700;
    color: #ffffff;
  }

  .score-divider {
    font-size: 2rem;
    font-weight: 700;
    color: #5fed83;
  }

  .winner-text {
    margin: 0 0 24px;
    font-size: 1.05rem;
    color: #c7f2d2;
  }

  .game-over-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .game-over-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 170px;
    padding: 14px 22px;
    border-radius: 999px;
    background: linear-gradient(135deg, #5fed83, #7cf4ff);
    color: #0a0a1a;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 18px 40px rgba(95, 237, 131, 0.18);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .game-over-button:hover {
    transform: translateY(-2px);
    opacity: 0.96;
  }
</style>
