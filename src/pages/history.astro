---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Mona Mayhem — Match History</title>
    <style>
      :root {
        --bg-dark: #0a0a1a;
        --green: #5fed83;
        --purple: #8a2be2;
        --red: #ff6b6b;
        --text: #ffffff;
        --text-secondary: #cccccc;
      }

      body {
        font-family: 'Courier New', monospace;
        background: var(--bg-dark);
        color: var(--text);
        margin: 0;
        padding: 20px;
        min-height: 100vh;
      }

      h1 {
        text-align: center;
        font-size: 2.5rem;
        color: var(--green);
        text-shadow: 0 0 10px var(--green), 0 0 20px var(--green);
        margin-bottom: 10px;
      }

      p {
        text-align: center;
        color: var(--text-secondary);
        margin-top: 0;
      }

      .page-actions {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
      }

      .history-button,
      .back-link {
        padding: 12px 22px;
        border: none;
        border-radius: 999px;
        text-decoration: none;
        color: var(--text);
        background: linear-gradient(45deg, var(--purple), var(--green));
        box-shadow: 0 0 15px rgba(95, 237, 131, 0.25);
        cursor: pointer;
        font-weight: bold;
      }

      .history-button:hover,
      .back-link:hover {
        transform: scale(1.03);
      }

      .history-panel {
        max-width: 1000px;
        margin: 0 auto;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(95, 237, 131, 0.2);
        border-radius: 14px;
        padding: 20px;
      }

      .history-table {
        width: 100%;
        border-collapse: collapse;
      }

      .history-table th,
      .history-table td {
        padding: 12px 14px;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .history-table th {
        color: var(--green);
        font-size: 0.95rem;
      }

      .history-table td {
        color: var(--text-secondary);
        font-size: 0.95rem;
      }

      .history-empty {
        text-align: center;
        padding: 60px 0;
        color: var(--text-secondary);
      }

      .result-winner {
        color: var(--green);
        font-weight: bold;
      }

      .result-loser {
        color: var(--text-secondary);
      }

      @media (max-width: 760px) {
        .history-table th,
        .history-table td {
          padding: 10px 8px;
        }
      }
    </style>
  </head>
  <body>
    <h1>Match History</h1>
    <p>All arena results are stored in your browser. They persist between games.</p>

    <div class="page-actions">
      <a class="back-link" href="/">← Back to Battle</a>
      <button class="history-button" id="clear-history">Clear History</button>
    </div>

    <div class="history-panel" id="history-panel">
      <div class="history-empty" id="history-empty">Loading history…</div>
      <table class="history-table" id="history-table" style="display:none;">
        <thead>
          <tr>
            <th>Time</th>
            <th>Players</th>
            <th>Score</th>
            <th>Result</th>
          </tr>
        </thead>
        <tbody id="history-body"></tbody>
      </table>
    </div>

    <script type="module" lang="ts" client:load>
      import { loadMatchHistory, clearMatchHistory } from '../lib/utils/matchHistory.ts';

      const historyBody = document.getElementById('history-body') as HTMLElement;
      const historyTable = document.getElementById('history-table') as HTMLElement;
      const historyEmpty = document.getElementById('history-empty') as HTMLElement;
      const clearHistoryButton = document.getElementById('clear-history') as HTMLButtonElement;

      function formatTime(timestamp: number) {
        return new Date(timestamp).toLocaleString();
      }

      function renderHistory() {
        console.log('[History] renderHistory called');
        const history = loadMatchHistory();
        console.log('[History] Loaded history:', history);

        if (history.length === 0) {
          console.log('[History] No history records found, showing empty message');
          historyEmpty.textContent = 'No matches recorded yet. Fight a battle first!';
          historyTable.style.display = 'none';
          return;
        }

        console.log('[History] Rendering', history.length, 'history records');
        historyBody.innerHTML = '';
        history.forEach(record => {
          const row = document.createElement('tr');
          const winnerLabel = record.winner === 1 ? record.player1 : record.player2;

          row.innerHTML = `
            <td>${formatTime(record.timestamp)}</td>
            <td>${record.player1} vs ${record.player2}</td>
            <td>${record.score1} – ${record.score2}</td>
            <td class="result-winner">${winnerLabel} wins</td>
          `;

          historyBody.appendChild(row);
        });

        historyTable.style.display = 'table';
        historyEmpty.textContent = '';
        console.log('[History] History rendered successfully');
      }

      function setupHistoryPage() {
        console.log('[History] setupHistoryPage called');
        clearHistoryButton.addEventListener('click', () => {
          console.log('[History] Clear history button clicked');
          clearMatchHistory();
          renderHistory();
        });

        renderHistory();
      }

      if (typeof window !== 'undefined') {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setupHistoryPage);
        } else {
          setupHistoryPage();
        }
      }
    </script>
  </body>
</html>
