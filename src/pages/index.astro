---
import GameOver from '../components/GameOver.astro';
// Power-Up System Integration for Mona Mayhem Battle Arena
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<style>
			/* Retro arcade theme colors */
			:root {
				--bg-dark: #0a0a1a;
				--green: #5fed83;
				--purple: #8a2be2;
				--red: #ff6b6b;
				--text: #ffffff;
				--text-secondary: #cccccc;
			}

			body {
				font-family: 'Courier New', monospace;
				background: var(--bg-dark);
				color: var(--text);
				margin: 0;
				padding: 20px;
				min-height: 100vh;
			}

			/* Title with neon glow */
			h1 {
				text-align: center;
				font-size: 2.5rem;
				color: var(--green);
				text-shadow: 0 0 10px var(--green), 0 0 20px var(--green);
				margin-bottom: 30px;
				animation: neon-pulse 2s ease-in-out infinite alternate;
			}

			@keyframes neon-pulse {
				from { text-shadow: 0 0 10px var(--green), 0 0 20px var(--green); }
				to { text-shadow: 0 0 15px var(--green), 0 0 30px var(--green), 0 0 40px var(--green); }
			}

			/* Battle arena container */
			.battle-arena {
				max-width: 1200px;
				margin: 0 auto;
				position: relative;
				min-height: 600px;
				border: 2px solid var(--green);
				border-radius: 10px;
				padding: 20px;
				background: linear-gradient(135deg, var(--bg-dark) 0%, #1a1a2e 100%);
				box-shadow: 0 0 20px rgba(95, 237, 131, 0.3);
			}

			/* Input section */
			.input-section {
				display: flex;
				justify-content: center;
				gap: 20px;
				margin-bottom: 30px;
				flex-wrap: wrap;
			}

			.input-group {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 10px;
			}

			input {
				padding: 10px 15px;
				border: 2px solid var(--purple);
				border-radius: 5px;
				background: var(--bg-dark);
				color: var(--text);
				font-size: 1rem;
				width: 200px;
				text-align: center;
			}

			input:focus {
				outline: none;
				border-color: var(--green);
				box-shadow: 0 0 10px var(--green);
			}

			label {
				color: var(--text-secondary);
				font-size: 0.9rem;
			}

			/* Battle button */
			.battle-button {
				padding: 15px 30px;
				background: linear-gradient(45deg, var(--purple), var(--green));
				border: none;
				border-radius: 5px;
				color: var(--text);
				font-size: 1.2rem;
				font-weight: bold;
				cursor: pointer;
				transition: all 0.3s ease;
				box-shadow: 0 0 10px rgba(138, 43, 226, 0.5);
			}

			.battle-button:hover {
				transform: scale(1.05);
				box-shadow: 0 0 20px rgba(138, 43, 226, 0.8);
			}

			.history-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 14px 24px;
				border-radius: 999px;
				text-decoration: none;
				color: var(--text);
				background: rgba(255, 255, 255, 0.08);
				border: 1px solid var(--purple);
				font-weight: bold;
				transition: transform 0.25s ease;
			}

			.history-link:hover {
				transform: scale(1.05);
			}

			.battle-button:disabled {
				opacity: 0.5;
				cursor: not-allowed;
			}

			/* Results section */
			.results-section {
				display: none;
				margin-top: 30px;
			}

			.player-result {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 20px;
				padding: 20px;
				border: 1px solid var(--green);
				border-radius: 5px;
				background: rgba(95, 237, 131, 0.1);
			}

			.player-info {
				flex: 1;
			}

			.player-name {
				font-size: 1.2rem;
				font-weight: bold;
				margin-bottom: 5px;
			}

			.player-stats {
				color: var(--text-secondary);
				font-size: 0.9rem;
			}

			.vs-badge {
				font-size: 2rem;
				font-weight: bold;
				color: var(--purple);
				text-shadow: 0 0 10px var(--purple);
				margin: 0 20px;
			}

			/* Power-up badges */
			.badge-container {
				display: flex;
				gap: 10px;
				flex-wrap: wrap;
				margin-top: 10px;
			}

			.badge {
				display: flex;
				align-items: center;
				gap: 5px;
				padding: 5px 10px;
				border-radius: 15px;
				font-size: 0.9rem;
				font-weight: bold;
				animation: badge-pulse 1s ease-in-out infinite alternate;
			}

			.badge-speed-boost {
				background: var(--green);
				color: var(--bg-dark);
			}

			.badge-shield {
				background: var(--purple);
				color: var(--text);
			}

			.badge-health {
				background: var(--red);
				color: var(--text);
			}

			@keyframes badge-pulse {
				from { transform: scale(1); }
				to { transform: scale(1.05); }
			}

			/* Power-up elements on arena */
			.powerup-element {
				position: absolute;
				width: 50px;
				height: 50px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.5rem;
				cursor: pointer;
				transition: all 0.3s ease;
				animation: powerup-float 2s ease-in-out infinite;
				z-index: 10;
			}

			.powerup-element:hover {
				transform: scale(1.2);
			}

			.powerup-speed-boost {
				background: radial-gradient(circle, var(--green), rgba(95, 237, 131, 0.3));
				box-shadow: 0 0 15px var(--green);
			}

			.powerup-shield {
				background: radial-gradient(circle, var(--purple), rgba(138, 43, 226, 0.3));
				box-shadow: 0 0 15px var(--purple);
			}

			.powerup-health {
				background: radial-gradient(circle, var(--red), rgba(255, 107, 107, 0.3));
				box-shadow: 0 0 15px var(--red);
			}

			@keyframes powerup-float {
				0%, 100% { transform: translateY(0px); }
				50% { transform: translateY(-10px); }
			}

			.powerup-element.collected {
				animation: powerup-collect 0.5s ease-out forwards;
			}

			@keyframes powerup-collect {
				0% { transform: scale(1); opacity: 1; }
				100% { transform: scale(0); opacity: 0; }
			}

			/* Loading and error states */
			.loading {
				text-align: center;
				color: var(--green);
				font-size: 1.1rem;
				animation: loading-pulse 1s ease-in-out infinite alternate;
			}

			@keyframes loading-pulse {
				from { opacity: 0.7; }
				to { opacity: 1; }
			}

			.error {
				text-align: center;
				color: var(--red);
				font-size: 1.1rem;
				padding: 10px;
				border: 1px solid var(--red);
				border-radius: 5px;
				margin: 20px 0;
			}

			/* Contribution grids */
			.contribution-grid {
				display: grid;
				grid-template-columns: repeat(53, 1fr);
				gap: 2px;
				margin-top: 10px;
			}

			.contribution-day {
				width: 10px;
				height: 10px;
				border-radius: 2px;
				background: #2d3748;
			}

			.contribution-day.level-1 { background: #9ca3af; }
			.contribution-day.level-2 { background: #10b981; }
			.contribution-day.level-3 { background: #059669; }
			.contribution-day.level-4 { background: #047857; }

			.game-over-overlay {
				position: fixed;
				inset: 0;
				display: none;
				align-items: center;
				justify-content: center;
				background: rgba(10, 10, 26, 0.9);
				z-index: 1000;
				padding: 20px;
			}

			.game-over-card {
				width: min(560px, 100%);
				background: rgba(20, 20, 44, 0.98);
				border: 1px solid rgba(95, 237, 131, 0.35);
				border-radius: 24px;
				box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
				padding: 36px 32px;
				text-align: center;
			}

			.game-over-card h2 {
				margin: 0;
				font-size: 2rem;
				color: #ffffff;
			}

			.game-over-card p {
				margin: 16px auto 22px;
				color: var(--text-secondary);
				max-width: 420px;
				line-height: 1.7;
			}

			.game-over-card .score-line {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 14px;
				margin: 20px 0 30px;
				font-size: 1.2rem;
				color: #ffffff;
			}

			.game-over-card .score-line strong {
				font-size: 1.8rem;
				color: #5fed83;
			}

			.game-over-card .game-over-actions {
				display: flex;
				justify-content: center;
				gap: 12px;
				flex-wrap: wrap;
			}

			.game-over-card .game-over-close {
				padding: 12px 20px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.08);
				color: #ffffff;
				border: 1px solid rgba(255, 255, 255, 0.12);
				cursor: pointer;
				transition: transform 0.2s ease, background 0.2s ease;
			}

			.game-over-card .game-over-close:hover {
				transform: translateY(-1px);
				background: rgba(255, 255, 255, 0.12);
			}

			/* Responsive design */
			@media (max-width: 768px) {
				.input-section {
					flex-direction: column;
					align-items: center;
				}

				.player-result {
					flex-direction: column;
					text-align: center;
				}

				.vs-badge {
					margin: 10px 0;
				}

				h1 {
					font-size: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<GameOver />
		<h1>Mona Mayhem</h1>
		<p style="text-align: center; color: var(--text-secondary); margin-bottom: 30px;">
			GitHub Contribution Battle Arena with Power-Ups!
		</p>

		<div class="battle-arena" id="battle-arena">
			<!-- Debug info -->
			<div id="debug-info" style="position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.8); color: white; padding: 5px; font-size: 12px; border-radius: 5px;">
				Active Power-ups: <span id="active-count">0</span>
			</div>
			<!-- Input Section -->
			<div class="input-section">
				<div class="input-group">
					<label for="player1">Player 1</label>
					<input type="text" id="player1" placeholder="GitHub username" value="octocat">
				</div>

				<button class="battle-button" id="battle-button">⚔️ Battle!</button>
				<a class="history-link" href="/history">📜 Match History</a>

				<div class="input-group">
					<label for="player2">Player 2</label>
					<input type="text" id="player2" placeholder="GitHub username" value="torvalds">
				</div>
			</div>

			<!-- Results Section -->
			<div class="results-section" id="results-section">
				<div class="player-result">
					<div class="player-info">
						<div class="player-name" id="player1-name">Player 1</div>
						<div class="player-stats" id="player1-stats">Loading...</div>
						<div class="contribution-grid" id="player1-grid"></div>
						<div class="badge-container" id="player1-badges"></div>
					</div>

					<div class="vs-badge">VS</div>

					<div class="player-info">
						<div class="player-name" id="player2-name">Player 2</div>
						<div class="player-stats" id="player2-stats">Loading...</div>
						<div class="contribution-grid" id="player2-grid"></div>
						<div class="badge-container" id="player2-badges"></div>
					</div>
				</div>
			</div>

			<!-- Loading/Error Messages -->
			<div id="loading-message" class="loading" style="display: none;">
				Loading contribution data...
			</div>
			<div id="winner-message" class="loading" style="display: none;"></div>
			<div id="error-message" class="error" style="display: none;"></div>
		</div>

		<div class="game-over-overlay" id="game-over-overlay">
			<div class="game-over-card">
				<h2 id="game-over-title">Game Over</h2>
				<p id="game-over-message">Battle complete. Review your final result.</p>
				<div class="score-line">
					<span id="game-over-players">Player 1 vs Player 2</span>
					<strong id="game-over-score">0 – 0</strong>
				</div>
				<div class="game-over-actions">
					<button class="game-over-close" id="game-over-close">Close</button>
				</div>
			</div>
		</div>

		<script type="module" lang="ts" client:load>
			import type { GameState, PowerUp, BattleResult } from '../lib/types/powerups';
			import { initializeGameState, spawnRandomPowerUp, collectPowerUp, checkExpiredPowerUps } from '../lib/utils/powerupManager';
			import { calculateBattleResult } from '../lib/utils/battleCalculation';
			import { POWERUP_CONFIGS, SPAWN_CONFIG } from '../lib/config/powerups';
			import { saveMatchResult } from '../lib/utils/matchHistory';

			// Global game state - single source of truth
			let gameState: GameState = initializeGameState();

			// Battle context for managing intervals
			let battleContext = {
				spawnIntervalId: null,
				expiryIntervalId: null,
				observerIntervalId: null,
				isBattleActive: false,
			};

			// DOM elements
			const battleButton = document.getElementById('battle-button') as HTMLButtonElement;
			const player1Input = document.getElementById('player1') as HTMLInputElement;
			const player2Input = document.getElementById('player2') as HTMLInputElement;
			const resultsSection = document.getElementById('results-section') as HTMLElement;
			const loadingMessage = document.getElementById('loading-message') as HTMLElement;
			const winnerMessage = document.getElementById('winner-message') as HTMLElement;
			const errorMessage = document.getElementById('error-message') as HTMLElement;
			const battleArena = document.getElementById('battle-arena') as HTMLElement;
			const gameOverOverlay = document.getElementById('game-over-overlay') as HTMLElement;
			const gameOverTitle = document.getElementById('game-over-title') as HTMLElement;
			const gameOverMessage = document.getElementById('game-over-message') as HTMLElement;
			const gameOverPlayers = document.getElementById('game-over-players') as HTMLElement;
			const gameOverScore = document.getElementById('game-over-score') as HTMLElement;
			const gameOverClose = document.getElementById('game-over-close') as HTMLButtonElement;

			// Game State Observer - polls for changes and updates UI
			class GameStateObserver {
				private previousActiveCount = 0;

				startWatching() {
					this.stopWatching(); // clear any existing interval
					battleContext.observerIntervalId = setInterval(() => {
						this.checkForChanges();
					}, 100); // check every 100ms
				}

				stopWatching() {
					if (battleContext.observerIntervalId) {
						clearInterval(battleContext.observerIntervalId);
						battleContext.observerIntervalId = null;
					}
				}

				private checkForChanges() {
					const currentCount = gameState.activePowerUps.size;
					if (currentCount !== this.previousActiveCount) {
						console.log(`[Observer] Active power-ups changed: ${this.previousActiveCount} → ${currentCount}`);
						this.previousActiveCount = currentCount;
						syncBadgesWithState();
					}
				}
			}

			const observer = new GameStateObserver();

			// Initialize observer when page loads
			document.addEventListener('DOMContentLoaded', () => {
				observer.startWatching();
			});

			// Reset battle state for new battle
			function resetBattleState() {
				// Clear existing power-ups and intervals
				if (battleContext.spawnIntervalId) {
					clearInterval(battleContext.spawnIntervalId);
					battleContext.spawnIntervalId = null;
				}
				if (battleContext.expiryIntervalId) {
					clearInterval(battleContext.expiryIntervalId);
					battleContext.expiryIntervalId = null;
				}

				// Reset game state
				gameState = initializeGameState();
				battleContext.isBattleActive = false;

				// Clear UI
				clearPowerUpElements();
				document.getElementById('player1-badges').innerHTML = '';
				document.getElementById('player2-badges').innerHTML = '';
				winnerMessage.style.display = 'none';
				hideGameOverScreen();
			}

			// Sync badge display with current game state
			function syncBadgesWithState() {
				const player1BadgeContainer = document.getElementById('player1-badges');
				const player2BadgeContainer = document.getElementById('player2-badges');

				// Clear existing badges
				player1BadgeContainer.innerHTML = '';
				player2BadgeContainer.innerHTML = '';

				// Render badge for each active power-up
				const activePowerUps = Array.from(gameState.activePowerUps.values());
				activePowerUps.forEach(powerUp => {
					if (!powerUp.collected) return; // Only show collected ones

					const config = POWERUP_CONFIGS[powerUp.type];
					const timeRemaining = powerUp.expiresAt ?
						Math.ceil((powerUp.expiresAt - Date.now()) / 1000) : 0;

					const badgeHTML = `
						<div class="badge badge-${powerUp.type}" data-powerup-id="${powerUp.id}">
							<span class="badge-icon">${config.emoji}</span>
							<span class="badge-timer">${timeRemaining}s</span>
						</div>
					`;

					// Both players see all power-ups (arena-wide scope)
					player1BadgeContainer.insertAdjacentHTML('beforeend', badgeHTML);
					player2BadgeContainer.insertAdjacentHTML('beforeend', badgeHTML);
				});
			}

			// Render power-up elements on the arena
			function renderPowerUpElements() {
				clearPowerUpElements(); // Clear existing

				const activePowerUps = Array.from(gameState.activePowerUps.values());

				// Update debug counter
				document.getElementById('active-count').textContent = activePowerUps.length.toString();

				activePowerUps.forEach(powerUp => {
					if (powerUp.collected) return; // Don't render collected ones

					const config = POWERUP_CONFIGS[powerUp.type];
					const element = document.createElement('div');
					element.className = `powerup-element powerup-${powerUp.type}`;
					element.dataset.powerupId = powerUp.id;
					element.textContent = config.emoji;
					element.style.left = `${powerUp.position.x}%`;
					element.style.top = `${powerUp.position.y}%`;

					// Add click handler
					element.addEventListener('click', () => {
						handlePowerUpClick(powerUp.id);
					});

					battleArena.appendChild(element);
				});
			}

			// Clear all power-up elements from DOM
			function clearPowerUpElements() {
				const elements = battleArena.querySelectorAll('.powerup-element');
				elements.forEach(el => el.remove());
				document.getElementById('active-count').textContent = '0';
			}

			// Handle power-up click
			function handlePowerUpClick(powerUpId: string) {
				const success = collectPowerUp(gameState, powerUpId);
				if (success) {
					// Add collected animation class
					const element = battleArena.querySelector(`[data-powerup-id="${powerUpId}"]`);
					if (element) {
						element.classList.add('collected');
						// Remove element after animation
						setTimeout(() => element.remove(), 500);
					}
				}
			}

			// Start power-up spawning during battle
			function startPowerUpSpawning() {
				if (!battleContext.isBattleActive) return;
				console.log('[PowerUp] startPowerUpSpawning called, active=', gameState.activePowerUps.size);

				battleContext.spawnIntervalId = setInterval(() => {
					if (!battleContext.isBattleActive) return;
					const newPowerUp = spawnRandomPowerUp(gameState);
					if (newPowerUp) {
						renderPowerUpElements(); // Re-render all power-ups
					} else {
						console.log('[PowerUp] Failed to spawn a new power-up this interval');
					}
				}, SPAWN_CONFIG.intervalMs);
			}

			// Start expiry checking
			function startExpiryChecking() {
				battleContext.expiryIntervalId = setInterval(() => {
					const expiredCount = checkExpiredPowerUps(gameState);
					if (expiredCount > 0) {
						renderPowerUpElements(); // Re-render to remove expired ones
					}
				}, 500); // Check every 500ms
			}

			function showGameOverScreen(result: BattleResult) {
				const player1Name = player1Input.value.trim() || 'Player 1';
				const player2Name = player2Input.value.trim() || 'Player 2';
				const winnerName = result.winner === 1 ? player1Name : player2Name;
				const message = result.score1 === result.score2 ? 'It’s a draw!' : `${winnerName} wins!`;

				gameOverTitle.textContent = 'Game Over';
				gameOverMessage.textContent = message;
				gameOverPlayers.textContent = `${player1Name} vs ${player2Name}`;
				gameOverScore.textContent = `${result.score1} – ${result.score2}`;
				gameOverOverlay.style.display = 'flex';
			}

			function hideGameOverScreen() {
				if (gameOverOverlay) {
					gameOverOverlay.style.display = 'none';
				}
			}

			// Mock contribution data (replace with actual API call)
			async function fetchContributions(username: string) {
				// Simulate API delay
				await new Promise(resolve => setTimeout(resolve, 1000));

				// Mock data - replace with actual API call to /api/contributions/[username]
				const mockData = {
					user: username,
					total: Math.floor(Math.random() * 1000) + 500,
					contributions: Array.from({ length: 365 }, (_, i) => ({
						date: new Date(Date.now() - i * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
						count: Math.floor(Math.random() * 10),
						level: Math.floor(Math.random() * 5) as 0 | 1 | 2 | 3 | 4
					}))
				};

				return mockData;
			}

			// Render contribution grid
			function renderContributionGrid(gridElement: HTMLElement, contributions: any[]) {
				gridElement.innerHTML = '';
				contributions.slice(0, 365).forEach(contrib => {
					const dayElement = document.createElement('div');
					dayElement.className = `contribution-day level-${contrib.level}`;
					dayElement.title = `${contrib.date}: ${contrib.count} contributions`;
					gridElement.appendChild(dayElement);
				});
			}

			// Main battle function
			async function startBattle() {
				const player1 = player1Input.value.trim();
				const player2 = player2Input.value.trim();

				if (!player1 || !player2) {
					showError('Please enter both usernames');
					return;
				}

				// Reset state and UI
				resetBattleState();
				hideError();
				showLoading();

				try {
					// Fetch contribution data in parallel
					const [data1, data2] = await Promise.all([
						fetchContributions(player1),
						fetchContributions(player2)
					]);

					// Update UI with player data
					document.getElementById('player1-name').textContent = data1.user;
					document.getElementById('player1-stats').textContent = `${data1.total} contributions`;
					renderContributionGrid(document.getElementById('player1-grid'), data1.contributions);

					document.getElementById('player2-name').textContent = data2.user;
					document.getElementById('player2-stats').textContent = `${data2.total} contributions`;
					renderContributionGrid(document.getElementById('player2-grid'), data2.contributions);

					// Start battle with power-ups
					battleContext.isBattleActive = true;
					const immediatePowerUp = spawnRandomPowerUp(gameState);
					if (immediatePowerUp) {
						renderPowerUpElements();
					}
					startPowerUpSpawning();
					startExpiryChecking();

					// Calculate result after a delay (simulating battle animation)
					setTimeout(() => {
						const result = calculateBattleResult(data1.contributions, data2.contributions, gameState);
						displayWinner(result);
					showGameOverScreen(result);
						// Clear power-up intervals when battle ends
						if (battleContext.spawnIntervalId) {
							clearInterval(battleContext.spawnIntervalId);
							battleContext.spawnIntervalId = null;
						}
						if (battleContext.expiryIntervalId) {
							clearInterval(battleContext.expiryIntervalId);
							battleContext.expiryIntervalId = null;
						}
					}, 8000); // Increased from 3000 to 8000ms to give more time for power-ups

				} catch (error) {
					showError('Failed to load contribution data. Please try again.');
					console.error('Battle error:', error);
				} finally {
					hideLoading();
				}
			}

			// Display battle winner
			function displayWinner(result: BattleResult) {
				const player1NameElement = document.getElementById('player1-name') as HTMLElement;
				const player2NameElement = document.getElementById('player2-name') as HTMLElement;
				const winnerElement = result.winner === 1 ? player1NameElement : player2NameElement;

				player1NameElement.textContent = player1Input.value.trim() || 'Player 1';
				player2NameElement.textContent = player2Input.value.trim() || 'Player 2';
				winnerElement.textContent += ' 🏆';

				// Update stats with final scores
				document.getElementById('player1-stats').textContent = `${result.score1} points`;
				document.getElementById('player2-stats').textContent = `${result.score2} points`;

				winnerMessage.textContent = `${result.winner === 1 ? player1NameElement.textContent : player2NameElement.textContent} wins!`;
				winnerMessage.style.display = 'block';

				console.log('[Battle] Saving match result to history...');
				saveMatchResult({
					id: `match-${Date.now()}`,
					player1: player1Input.value.trim() || 'Player 1',
					player2: player2Input.value.trim() || 'Player 2',
					score1: result.score1,
					score2: result.score2,
					winner: result.winner,
					timestamp: Date.now(),
				});
				console.log('[Battle] Match result saved');

				console.log('[Battle] Result:', result);
			}

			// UI helper functions
			function showLoading() {
				loadingMessage.style.display = 'block';
				resultsSection.style.display = 'none';
				battleButton.disabled = true;
				winnerMessage.style.display = 'none';
			}

			function hideLoading() {
				loadingMessage.style.display = 'none';
				resultsSection.style.display = 'block';
				battleButton.disabled = false;
			}

			function showError(message: string) {
				errorMessage.textContent = message;
				errorMessage.style.display = 'block';
			}

			function hideError() {
				errorMessage.style.display = 'none';
			}

			// Event listeners
			battleButton.addEventListener('click', startBattle);
			gameOverClose.addEventListener('click', hideGameOverScreen);

			// Enter key support
			[player1Input, player2Input].forEach(input => {
				input.addEventListener('keypress', (e) => {
					if (e.key === 'Enter') {
						startBattle();
					}
				});
			});
		</script>
	</body>
</html>
